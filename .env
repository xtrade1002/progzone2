MAIL_RECIPIENT_PROGZONE_DE=info@progzone.de

MAIL_MAILER_PROGZONE_HU=progzone_hu
MAIL_HOST_PROGZONE_HU=smtp.progzone.hu
MAIL_PORT_PROGZONE_HU=587
MAIL_USERNAME_PROGZONE_HU=info@progzone.hu
MAIL_PASSWORD_PROGZONE_HU=change-me-progzone-hu
