APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:HNo+POA7XyHuv8etFD4KsPT3X9ff2fTncaR8G2L3N6c=
APP_DEBUG=true
APP_URL=http://localhost:8020

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=progzone2
DB_USERNAME=progzone2
DB_PASSWORD=progzone2

# Cache & Queue
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail (Hostinger SMTP konfiguráció)
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=your-hostinger-email@progzone.hu
MAIL_PASSWORD=your-hostinger-email-password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
FORM_NOTIFICATION_TO_EMAIL=info@progzone.hu

# Vite / Frontend
VITE_DEV_SERVER_HOST=localhost
VITE_DEV_SERVER_PORT=5187

# Cloudflare Turnstile (local development test keys)
CLOUDFLARE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
CLOUDFLARE_TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
CLOUDFLARE_TURNSTILE_TIMEOUT=8
