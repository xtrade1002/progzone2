APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:HNo+POA7XyHuv8etFD4KsPT3X9ff2fTncaR8G2L3N6c=
APP_DEBUG=false
APP_URL=http://localhost:8020

# Comma separated list of domains to use as a fallback when the current host
# has no dedicated price entries. Example: progzone.hu,progzone.de
PRICE_FALLBACK_DOMAINS=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=progzone2
DB_USERNAME=progzone2
DB_PASSWORD=progzone2

# Cache & Queue
BROADCAST_DRIVER=log
CACHE_STORE=file
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

# Mail (Mailjet SMTP konfiguráció)
MAIL_MAILER=mailjet
MAIL_HOST=in-v3.mailjet.com
MAIL_PORT=587
MAIL_USERNAME=your-mailjet-api-key
MAIL_PASSWORD=your-mailjet-secret-key
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Opcionális Mailjet specifikus beállítások
# MAILJET_HOST=in-v3.mailjet.com
# MAILJET_PORT=587
# MAILJET_USERNAME=
# MAILJET_PASSWORD=
# MAILJET_SCHEME=tls

# Domain specifikus SMTP konfigurációk
MAIL_MAILER_DEFAULT=progzone_de
MAIL_RECIPIENT_DEFAULT=info@progzone.de
MAIL_FROM_ADDRESS_DEFAULT=info@progzone.de
MAIL_FROM_NAME_DEFAULT="Progzone"

