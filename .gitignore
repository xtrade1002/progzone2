# Laravel / PHP dependencies
/vendor/

# Node dependencies
/node_modules/

# Public storage symlink and local keys
/public/storage
/storage/*.key

# Environment files
.env
.env.production
.env.backup
.env.local

# NPM / Yarn / PNPM logs and local lockfile
npm-debug.log
yarn-error.log
pnpm-debug.log
package-lock.json

# IDE / editor files
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Docker local overrides
docker-compose.override.yml
*.pid
*.seed
*.pid.lock

# Vite dev server hot file
/public/hot

# Laravel runtime/cache
/bootstrap/cache/*.php
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/storage/logs/*

# Keep Laravel placeholder files
!/bootstrap/cache/.gitignore
!/storage/framework/cache/.gitignore
!/storage/framework/sessions/.gitignore
!/storage/framework/testing/.gitignore
!/storage/framework/views/.gitignore
!/storage/logs/.gitignore
